  gem "jekyll-feed"
  gem "jekyll-sitemap"
  gem "jekyll-include-cache"
  gem "jekyll-redirect-from"
  gem "jemoji"
end

gem "tzinfo", ">= 1", "< 3"
gem "tzinfo-data"
